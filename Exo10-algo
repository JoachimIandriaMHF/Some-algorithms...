Algorithme SmartOrderSystem

Variable
  var itemName:CHAINE;
  var unit Price:REEL;
  var quantity: ENTIER;
  var taxRate: REEL ;
  var toralPrice:REEL ;
Debut 
  *Dialogue d'accueil du robot*
  AFFICHER ("---WELCOME TO THE AUTO_SHOP MHF---");
  AFFICHER ("I am your digital assistant. What would you like to buy?");
  LIRE(itemName);
  
  AFFICHER ("Great choice! What is the price of the one ",itemName,"?");
  LIRE (unit Price);
  
  AFFICHER ("And how many units do you need?")
  LIRE (quantity);
  *Equation simple:Total =(Prix*Quantity)+Taxe*
  *On utilise un taux de taxe fixe de 20%*
  taxeRate<-0.20;
  totalPrice<-(unitPrice*quantity)*(1+taxeRate);
 
  *Conclusion de la commande *
  AFFICHER ("Processing your order for:",itemName);
  AFFICHER ("The total price (including 20%tax)is:",totalPrice );
  AFFICHER ("Thank you for your purchase! Have a nice day.");
Fin


